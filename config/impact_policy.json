        "step_2": 90.0,
        "step_3": 90.0
      }
    },
    "feature/*": {
      "min_overall_program_score": 80.0,
      "min_step_scores": {
        "step_1": 80.0,
        "step_2": 80.0,
        "step_3": 80.0
      }
    }
  }
