{
  "blocked_until_future_wave": [
    {
      "item": "broad automatic patch application",
      "reason": "SafetyGate declares eligibility only; mutation remains blocked until a narrow pattern has repeated benchmark, verifier, trajectory, and rollback proof."
    },
    {
      "item": "automatic merge authorization",
      "reason": "SafetyGate decisions never authorize merging."
    },
    {
      "item": "automatic security remediation or dismissal",
      "reason": "Security findings remain review-first without an explicitly reviewed and independently verified policy."
    },
    {
      "item": "automatic release publication",
      "reason": "Release and Trusted Publishing decisions remain human-owned protected operations."
    },
    {
      "item": "hosted service or cloud infrastructure",
      "reason": "Local file-backed orchestration is implemented; hosted deployment remains deferred until adoption demand is proven."
    }
  ],
  "completed_downstream_capabilities": [
    "TrajectoryStore",
    "RepoMemory",
    "ReplayableBenchmarkHarness",
    "ProtectedVerifier",
    "PatchScorer",
    "PRReporter",
    "local diagnostic queue and worker"
  ],
  "depends_on": "docs/contracts/failure-vector-support-matrix.v1.json",
  "global_blocked_actions": [
    "delete or weaken tests",
    "skip CI or verifier checks",
    "edit workflow gates to hide the failure",
    "modify files outside allowed_files"
  ],
  "next_lane_after_completion": "Cross-provider adoption and real-repository evidence",
  "policy_by_failure_class": [
    {
      "allowed_files_policy": "affected_files_only",
      "default_decision": "safe_fix_allowed_if_all_global_conditions_pass",
      "failure_class": "formatter_only",
      "review_first_when": [
        "affected_files is empty",
        "scope is not pr_owned_only",
        "risk is not low",
        "safe_fix_candidate is false",
        "local_repro_command is empty"
      ]
    },
    {
      "allowed_files_policy": "affected_files_only",
      "default_decision": "safe_fix_allowed_if_all_global_conditions_pass",
      "failure_class": "lint",
      "review_first_when": [
        "lint is not mechanically fixable",
        "affected_files is empty",
        "scope is not pr_owned_only",
        "risk is not low",
        "safe_fix_candidate is false",
        "local_repro_command is empty"
      ]
    },
    {
      "allowed_files_policy": "none",
      "default_decision": "review_first",
      "failure_class": "test",
      "review_first_when": [
        "always in current policy"
      ]
    },
    {
      "allowed_files_policy": "none",
      "default_decision": "review_first",
      "failure_class": "type",
      "review_first_when": [
        "always in current policy"
      ]
    },
    {
      "allowed_files_policy": "none",
      "default_decision": "review_first",
      "failure_class": "dependency",
      "review_first_when": [
        "always in current policy"
      ]
    },
    {
      "allowed_files_policy": "none",
      "default_decision": "review_first",
      "failure_class": "merge_conflict",
      "review_first_when": [
        "always in current policy"
      ]
    },
    {
      "allowed_files_policy": "none",
      "default_decision": "review_first",
      "failure_class": "unknown",
      "review_first_when": [
        "always in current policy"
      ]
    }
  ],
  "purpose": "Documents the current SafetyGate policy and preserves narrow review-first eligibility without relisting implemented downstream platform layers as future work.",
  "roadmap_lane": "Foundation / SafetyGate",
  "safe_fix_allowed_only_when": {
    "affected_files": "non_empty",
    "failure_class_in": [
      "formatter_only",
      "lint"
    ],
    "local_repro_command": "non_empty",
    "risk": "low",
    "safe_fix_candidate": true,
    "scope": "pr_owned_only"
  },
  "schema_version": "sdetkit.safety_gate.policy_matrix.v1"
}
