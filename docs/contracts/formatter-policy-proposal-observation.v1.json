{
  "allowed_decisions": [
    "accept",
    "reject",
    "defer",
    "request_more_evidence"
  ],
  "allowed_metric_outcomes": [
    "pass",
    "fail",
    "not_applicable"
  ],
  "authority_boundary": {
    "automation_allowed": false,
    "merge_authorized": false,
    "patch_application_allowed": false,
    "publication_authorized": false,
    "security_dismissal_allowed": false,
    "semantic_equivalence_proven": false
  },
  "metric_definitions": [
    {
      "description": "The reviewed record remains bound to the exact formatter proposal artifact and source identity.",
      "metric_id": "exact_evidence_binding"
    },
    {
      "description": "The proposed file scope and expected diff shape are clear enough for human review.",
      "metric_id": "proposal_scope_clarity"
    },
    {
      "description": "The focused and broader proof plan is concrete, bounded, and actionable.",
      "metric_id": "proof_plan_actionability"
    },
    {
      "description": "The rollback path is explicit and sufficient for the proposed mechanical change.",
      "metric_id": "rollback_clarity"
    },
    {
      "description": "The proposal preserves review-first and all denied authority boundaries.",
      "metric_id": "authority_boundary_preservation"
    },
    {
      "description": "The proposal gives the reviewer a useful decision without overstating proof or maturity.",
      "metric_id": "operator_usefulness"
    }
  ],
  "required_observation_fields": [
    "observation_id",
    "proposal_path",
    "proposal_sha256",
    "source_repository",
    "source_commit_sha",
    "source_pr_number",
    "reviewer_id",
    "reviewed_at",
    "decision",
    "decision_reason",
    "metric_outcomes",
    "review_notes"
  ],
  "required_report_fields": [
    "schema_version",
    "report_status",
    "input_provenance",
    "reviewed_observation_count",
    "decision_counts",
    "metrics",
    "failed_metric_ids",
    "false_authority_count",
    "next_human_action",
    "authority_boundary"
  ],
  "rules": {
    "branch_execution_allowed": false,
    "broader_maturity_claim_allowed": false,
    "history_authorizes_current_action": false,
    "observations_are_authority": false,
    "reviewed_observations_only": true,
    "source_proposal_digest_required": true,
    "source_proposal_execution_must_be_denied": true,
    "source_proposal_must_be_eligible": true,
    "target_repo_mutation": false
  },
  "schema_version": "sdetkit.formatter_policy_proposal_observation_contract.v1"
}
