{
  "allowed_candidate_families": [
    "formatter_only"
  ],
  "allowed_proof_statuses": [
    "pass",
    "fail",
    "blocked",
    "not_run"
  ],
  "allowed_reviewer_decisions": [
    "accept",
    "reject",
    "defer",
    "request_more_evidence"
  ],
  "allowed_scenario_outcomes": [
    "pass",
    "fail",
    "blocked"
  ],
  "authority_boundary": {
    "automation_allowed": false,
    "merge_authorized": false,
    "patch_application_allowed": false,
    "publication_authorized": false,
    "security_dismissal_allowed": false,
    "semantic_equivalence_proven": false
  },
  "evidence_schema_version": "sdetkit.remediation_research_evidence.v1",
  "purpose": "Versioned, deterministic, local-first evidence contract for evaluating one reversible PR-owned mechanical remediation family without changing SafetyGate policy or granting mutation authority.",
  "report_schema_version": "sdetkit.remediation_research_report.v1",
  "required_evidence_fields": [
    "schema_version",
    "candidate_family",
    "failure_class",
    "source_repository",
    "source_commit_sha",
    "pr_number",
    "pr_owned_scope",
    "before_inventory",
    "after_inventory",
    "proposed_diff",
    "focused_proof",
    "full_proof",
    "rollback",
    "reviewer_record",
    "false_authority_count",
    "limitations",
    "scenarios"
  ],
  "required_report_fields": [
    "schema_version",
    "report_status",
    "ok",
    "input_provenance",
    "candidate",
    "normalized_evidence",
    "validation_errors",
    "readiness_reasons",
    "scenario_summary",
    "rules",
    "authority_boundary"
  ],
  "required_scenarios": {
    "ambiguous": "blocked",
    "no_op": "pass",
    "oracle": "pass",
    "out_of_scope": "blocked",
    "rollback": "pass",
    "unsafe_patch": "blocked"
  },
  "rules": {
    "before_after_inventory_required": true,
    "exact_source_digests_required": true,
    "false_authority_count_required": true,
    "focused_and_full_proof_required": true,
    "history_is_advisory_only": true,
    "limitations_required": true,
    "local_first_only": true,
    "no_direct_main_mutation": true,
    "no_safety_gate_policy_change": true,
    "proposed_diff_required": true,
    "reviewer_record_required": true,
    "rollback_required": true,
    "target_repo_mutation": false,
    "test_weakening_allowed": false
  },
  "schema_version": "sdetkit.remediation_research_contract.v1"
}
